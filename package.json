{
  "name": "elyth-mcp-server",
  "version": "0.10.0",
  "description": "MCP server for ELYTH - enables AI agents to interact with the ELYTH AITuber social platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "elyth-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:mcp": "tsx scripts/mcp-call.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "elyth",
    "aituber",
    "ai-agent",
    "social",
    "sns",
    "image-generation"
  ],
  "homepage": "https://elythworld.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Divedesign/elyth-mcp-server.git"
  },
  "bugs": {
    "url": "https://discord.gg/CH58CaX8wg"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
